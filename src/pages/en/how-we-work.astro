---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionBadge from '../../components/shared/SectionBadge.astro';
import CTAButton from '../../components/shared/CTAButton.astro';
import { t, getLocalePath } from '../../i18n/index';

const locale = 'en';

const steps = [
  { num: '01', key: 'step1', color: 'from-cta-teal to-cta-teal/80', accent: 'border-cta-teal/30', glow: 'bg-cta-teal/10' },
  { num: '02', key: 'step2', color: 'from-warm-gold to-warm-gold/80', accent: 'border-warm-gold/30', glow: 'bg-warm-gold/10' },
  { num: '03', key: 'step3', color: 'from-royal-blue to-royal-blue-2', accent: 'border-royal-blue/30', glow: 'bg-royal-blue/10' },
  { num: '04', key: 'step4', color: 'from-cta-teal to-cta-teal/80', accent: 'border-cta-teal/30', glow: 'bg-cta-teal/10' },
];
---

<PageLayout locale={locale} pageKey="howWeWork">

  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-royal-blue via-royal-blue-2 to-royal-blue"></div>
    <div class="absolute top-20 right-20 w-72 h-72 bg-warm-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-10 w-96 h-96 bg-cta-teal/10 rounded-full blur-3xl"></div>

    <!-- Header spacer -->
    <div class="h-24"></div>

    <div class="relative z-10 px-6 lg:px-12 pt-16 pb-24 lg:pb-32">
      <div class="max-w-7xl mx-auto text-center">
        <SectionBadge text={t(locale, 'process.badge')} variant="dark" />
        <h1 class="text-4xl lg:text-6xl text-white font-bold max-w-4xl mx-auto leading-tight">
          {t(locale, 'process.title')} <span class="text-warm-gold">{t(locale, 'process.titleHighlight')}</span>
        </h1>
        <p class="mt-6 text-lg lg:text-xl text-white/70 max-w-3xl mx-auto leading-relaxed">
          {t(locale, 'process.subtitle')}
        </p>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="relative px-6 lg:px-12 py-16 lg:py-24 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-2xl lg:text-3xl font-bold text-royal-blue leading-tight">
        We don't start with financing.
      </p>
      <p class="text-2xl lg:text-3xl font-bold text-warm-gold leading-tight mt-2">
        We start with the structure that makes it possible.
      </p>
      <p class="mt-8 text-lg text-gray-600 leading-relaxed max-w-2xl mx-auto">
        {t(locale, 'process.subtitle')}
      </p>
    </div>
  </section>

  <!-- 4-Step Visual Timeline -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-royal-blue via-royal-blue-2 to-royal-blue"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-warm-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-cta-teal/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 px-6 lg:px-12 py-16 lg:py-32">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl text-white font-bold">
            The 4 stages of our process
          </h2>
          <p class="mt-4 text-white/60 text-lg">
            Each stage builds the next. None can be skipped.
          </p>
        </div>

        <!-- Timeline Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          {steps.map((step) => (
            <a href={getLocalePath(locale, 'services')} class="group relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl p-8 hover:bg-white/10 transition duration-500 overflow-hidden block">
              <div class="absolute inset-0 bg-gradient-to-br from-cta-teal/10 to-transparent opacity-0 group-hover:opacity-100 transition duration-500"></div>
              <div class="relative z-10">
                <!-- Step Number -->
                <div class:list={['w-14 h-14 rounded-2xl flex items-center justify-center mb-6', `bg-gradient-to-br ${step.color}`]}>
                  <span class="text-white font-bold text-lg">{step.num}</span>
                </div>

                <!-- Step Content -->
                <h3 class="text-xl font-bold text-white mb-3">
                  {t(locale, `process.${step.key}.title`)}
                </h3>
                <p class="text-white/70 text-sm leading-relaxed mb-4">
                  {t(locale, `process.${step.key}.description`)}
                </p>

                <!-- Link Arrow -->
                <div class="flex items-center text-cta-teal text-sm font-semibold group-hover:gap-2 gap-1 transition-all duration-300">
                  <span>{t(locale, `process.${step.key}.cta`)}</span>
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Connector line (desktop only) -->
        <div class="hidden lg:block relative h-1 max-w-5xl mx-auto -mt-2 mb-8">
          <div class="absolute inset-0 bg-gradient-to-r from-cta-teal via-warm-gold to-cta-teal rounded-full opacity-30"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Optimization (Special Cases) Section -->
  <section class="relative px-6 lg:px-12 py-16 lg:py-24 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="relative bg-gradient-to-br from-warm-gold/10 to-warm-gold/5 border border-warm-gold/20 rounded-3xl p-8 lg:p-12 overflow-hidden">
        <div class="absolute top-0 right-0 w-48 h-48 bg-warm-gold/10 rounded-full blur-3xl"></div>

        <div class="relative z-10 text-center">
          <SectionBadge text="OPTIMIZATION" variant="light" />
          <h2 class="text-3xl lg:text-4xl font-bold text-royal-blue leading-tight">
            {t(locale, 'process.special.title')}
          </h2>
          <p class="mt-4 text-lg text-gray-600 leading-relaxed max-w-2xl mx-auto">
            {t(locale, 'process.special.description')}
          </p>
          <div class="mt-8">
            <CTAButton href={getLocalePath(locale, 'services')} text={t(locale, 'process.special.cta')} variant="outline" arrow={true} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-royal-blue via-royal-blue-2 to-royal-blue"></div>
    <div class="absolute top-10 left-1/2 -translate-x-1/2 w-96 h-96 bg-warm-gold/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 px-6 lg:px-12 py-16 lg:py-24">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl lg:text-4xl text-white font-bold leading-tight max-w-3xl mx-auto">
          {t(locale, 'finalCta.title')}
        </h2>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <CTAButton href={getLocalePath(locale, 'compatibility')} text={t(locale, 'finalCta.cta')} variant="primary" arrow={true} />
          <CTAButton href={getLocalePath(locale, 'services')} text={t(locale, 'nav.services')} variant="secondary" />
        </div>
      </div>
    </div>
  </section>

</PageLayout>
