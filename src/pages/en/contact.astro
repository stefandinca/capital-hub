---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionBadge from '../../components/shared/SectionBadge.astro';
import CTAButton from '../../components/shared/CTAButton.astro';
import { t, getLocalePath } from '../../i18n/index';
import { site } from '../../data/site';

const locale = 'en';
---

<PageLayout locale={locale} pageKey="contact">

  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-royal-blue via-royal-blue-2 to-royal-blue"></div>
    <div class="absolute top-20 right-20 w-72 h-72 bg-warm-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-10 w-96 h-96 bg-cta-teal/10 rounded-full blur-3xl"></div>

    <div class="h-24"></div>

    <div class="relative z-10 px-6 lg:px-12 pt-16 pb-24 lg:pb-32">
      <div class="max-w-7xl mx-auto text-center">
        <SectionBadge text={t(locale, 'contact.badge')} variant="dark" />
        <h1 class="text-4xl lg:text-6xl text-white font-bold max-w-4xl mx-auto leading-tight">
          {t(locale, 'contact.title')} <span class="text-warm-gold">{t(locale, 'contact.titleHighlight')}</span>
        </h1>
        <p class="mt-6 text-lg lg:text-xl text-white/70 max-w-3xl mx-auto leading-relaxed">
          {t(locale, 'contact.subtitle')}
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info + Form -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-royal-blue to-royal-blue-2"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-cta-teal/5 rounded-full blur-3xl"></div>

    <div class="relative z-10 px-6 lg:px-12 py-16 lg:py-24">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

          <!-- Contact Info -->
          <div class="flex flex-col justify-center">
            <h2 class="text-3xl lg:text-4xl text-white font-bold mb-8">
              {t(locale, 'contact.schedule')}
            </h2>

            <div class="space-y-6">
              <!-- Phone -->
              <a href={`tel:${site.phoneRaw}`} class="flex items-center gap-5 group">
                <div class="w-14 h-14 bg-cta-teal/20 rounded-xl flex items-center justify-center group-hover:bg-cta-teal/30 transition duration-300">
                  <svg class="w-6 h-6 text-cta-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-white/50 mb-1">{t(locale, 'contact.phone')}</p>
                  <p class="text-lg text-white font-semibold group-hover:text-cta-teal transition duration-300">{site.phone}</p>
                </div>
              </a>

              <!-- Email -->
              <a href={`mailto:${site.email}`} class="flex items-center gap-5 group">
                <div class="w-14 h-14 bg-warm-gold/20 rounded-xl flex items-center justify-center group-hover:bg-warm-gold/30 transition duration-300">
                  <svg class="w-6 h-6 text-warm-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-white/50 mb-1">{t(locale, 'contact.email')}</p>
                  <p class="text-lg text-white font-semibold group-hover:text-warm-gold transition duration-300">{site.email}</p>
                </div>
              </a>

              <!-- WhatsApp -->
              <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="flex items-center gap-5 group">
                <div class="w-14 h-14 bg-emerald-500/20 rounded-xl flex items-center justify-center group-hover:bg-emerald-500/30 transition duration-300">
                  <svg class="w-6 h-6 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-white/50 mb-1">WhatsApp</p>
                  <p class="text-lg text-white font-semibold group-hover:text-emerald-400 transition duration-300">{t(locale, 'contact.whatsapp')}</p>
                </div>
              </a>
            </div>
          </div>

          <!-- Contact Form -->
          <div>
            <form
              id="contact-form"
              class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl p-8 lg:p-10"
            >
              <div id="contact-form-status" class="hidden mb-6 text-center py-4 rounded-xl text-sm font-semibold"></div>

              <div class="space-y-6">
                <!-- Name -->
                <div>
                  <label class="block text-sm text-white/70 mb-2">{t(locale, 'contact.form.name')}</label>
                  <input
                    type="text"
                    name="name"
                    required
                    class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/40 text-sm focus:outline-none focus:border-cta-teal transition duration-300"
                    placeholder={t(locale, 'contact.form.namePlaceholder')}
                  />
                </div>

                <!-- Email -->
                <div>
                  <label class="block text-sm text-white/70 mb-2">{t(locale, 'contact.form.email')}</label>
                  <input
                    type="email"
                    name="email"
                    required
                    class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/40 text-sm focus:outline-none focus:border-cta-teal transition duration-300"
                    placeholder={t(locale, 'contact.form.emailPlaceholder')}
                  />
                </div>

                <!-- Phone -->
                <div>
                  <label class="block text-sm text-white/70 mb-2">{t(locale, 'contact.form.phone')}</label>
                  <input
                    type="tel"
                    name="phone"
                    class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/40 text-sm focus:outline-none focus:border-cta-teal transition duration-300"
                    placeholder={t(locale, 'contact.form.phonePlaceholder')}
                  />
                </div>

                <!-- Message -->
                <div>
                  <label class="block text-sm text-white/70 mb-2">{t(locale, 'contact.form.message')}</label>
                  <textarea
                    name="message"
                    rows="5"
                    required
                    class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/40 text-sm focus:outline-none focus:border-cta-teal transition duration-300 resize-none"
                    placeholder={t(locale, 'contact.form.messagePlaceholder')}
                  ></textarea>
                </div>

                <!-- Submit -->
                <button
                  type="submit"
                  class="w-full inline-flex items-center justify-center gap-2 py-4 px-8 rounded-full text-sm font-semibold bg-cta-teal hover:bg-warm-gold text-white shadow-xl hover:scale-105 transition ease-in-out duration-300"
                >
                  {t(locale, 'contact.form.submit')}
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </button>
              </div>
            </form>
          </div>

        </div>
      </div>
    </div>
  </section>

<script>
  import { submitContactForm } from '../../lib/submit-contact';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('contact-form-status')!;
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
  const originalText = submitBtn?.innerHTML;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    statusEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<svg class="animate-spin w-5 h-5 mx-auto" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>';

    try {
      const formData = new FormData(form);
      await submitContactForm(formData, 'en');
      statusEl.textContent = 'Message sent successfully! We will get back to you shortly.';
      statusEl.className = 'mb-6 text-center py-4 rounded-xl text-sm font-semibold bg-emerald-500/20 text-emerald-300';
      form.reset();
    } catch (err) {
      statusEl.textContent = 'An error occurred. Please try again.';
      statusEl.className = 'mb-6 text-center py-4 rounded-xl text-sm font-semibold bg-red-500/20 text-red-300';
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });
</script>

</PageLayout>
