---
// Branded redirect to default locale
---

<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="refresh" content="0;url=/ro/" />
  <link rel="icon" type="image/png" href="/img/capital_hub_logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
  <title>Capital Hub Finance</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #1A3C6E 0%, #112F5A 50%, #1A3C6E 100%);
      font-family: 'Work Sans', sans-serif;
    }
    .container {
      text-align: center;
      animation: fadeIn 0.4s ease;
    }
    .logo { width: 64px; height: 64px; margin-bottom: 20px; }
    .brand { color: #fff; font-size: 22px; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 8px; }
    .spinner {
      width: 24px; height: 24px;
      border: 3px solid rgba(255,255,255,0.15);
      border-top-color: #2CA58D;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      margin: 20px auto 0;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body>
  <div class="container">
    <img src="/img/capital_hub_logo.png" alt="Capital Hub" class="logo" />
    <div class="brand">CAPITAL HUB</div>
    <div class="spinner"></div>
  </div>
  <script>window.location.href = '/ro/';</script>
</body>
</html>
