---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionBadge from '../../components/shared/SectionBadge.astro';
import CTAButton from '../../components/shared/CTAButton.astro';
import TeamMember from '../../components/team/TeamMember.astro';
import { t, getLocalePath } from '../../i18n/index';
import ro from '../../i18n/translations/ro.json';

const locale = 'ro';
const tm = ro.team;

const leadership = [
  { photo: '/dev/img/Ciprian.jpeg', banner: 'blue' as const,   data: tm.leadership.members.ciprian },
  { photo: '/dev/img/Iulia.jpeg',   banner: 'teal' as const,   data: tm.leadership.members.iulia },
  { photo: '/dev/img/Dan.jpeg',     banner: 'gold' as const,   data: tm.leadership.members.dan },
  { photo: undefined,               banner: 'blue-2' as const, data: tm.leadership.members.sorin },
];

const experts = [
  { photo: undefined, banner: 'teal' as const,   data: tm.experts.members.adina },
  { photo: undefined, banner: 'gold' as const,   data: tm.experts.members.bogdan },
  { photo: undefined, banner: 'blue-2' as const, data: tm.experts.members.robert },
];
---

<PageLayout locale={locale} pageKey="team">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-royal-blue via-royal-blue-2 to-royal-blue pt-32 pb-20 px-6">
    <div class="absolute top-20 right-20 w-72 h-72 bg-warm-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-96 h-96 bg-cta-teal/8 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-warm-gold/5 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-5xl mx-auto text-center">
      <SectionBadge text={t(locale, 'team.badge')} variant="dark" />

      <h1 class="text-3xl lg:text-5xl text-white font-bold leading-tight mt-4">
        {t(locale, 'team.heroTitle')}
      </h1>
      <p class="text-2xl lg:text-4xl text-warm-gold font-bold mt-4">
        {t(locale, 'team.heroSubtitle')}
      </p>
      <p class="text-white/80 text-lg leading-relaxed mt-8 max-w-3xl mx-auto">
        {t(locale, 'team.heroDescription')}
      </p>
    </div>
  </section>

  <!-- Leadership -->
  <section class="py-16 lg:py-24 px-6 bg-off-off-white relative overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-royal-blue/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-warm-gold/5 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="text-center mb-12 lg:mb-16">
        <SectionBadge text={t(locale, 'team.leadership.sectionBadge')} variant="light" />
        <h2 class="text-3xl lg:text-4xl text-royal-blue font-bold">
          {t(locale, 'team.leadership.sectionTitle')}
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {leadership.map((m) => (
          <TeamMember
            variant="leadership"
            banner={m.banner}
            photo={m.photo}
            alt={m.data.name}
            name={m.data.name}
            role={m.data.role}
            bio={m.data.bio}
            strengthsLabel={m.data.strengthsLabel}
            strengths={m.data.strengths}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Experts -->
  <section class="py-16 lg:py-24 px-6 bg-white relative overflow-hidden">
    <div class="absolute top-10 right-10 w-80 h-80 bg-cta-teal/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-72 h-72 bg-warm-gold/5 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="text-center mb-12 lg:mb-16">
        <SectionBadge text={t(locale, 'team.experts.sectionBadge')} variant="light" />
        <h2 class="text-3xl lg:text-4xl text-royal-blue font-bold">
          {t(locale, 'team.experts.sectionTitle')}
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {experts.map((m) => (
          <TeamMember
            variant="expert"
            banner={m.banner}
            photo={m.photo}
            alt={m.data.name}
            name={m.data.name}
            role={m.data.role}
            bio={m.data.bio}
            strengthsLabel={m.data.strengthsLabel}
            strengths={m.data.strengths}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24 px-6 bg-gradient-to-br from-royal-blue via-royal-blue-2 to-royal-blue relative overflow-hidden">
    <div class="absolute top-10 left-10 w-72 h-72 bg-warm-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-80 h-80 bg-cta-teal/10 rounded-full blur-3xl"></div>

    <div class="max-w-3xl mx-auto text-center relative z-10">
      <h2 class="text-2xl lg:text-4xl text-white font-bold mb-4">
        {t(locale, 'team.ctaTitle')}
      </h2>
      <p class="text-white/80 leading-relaxed mb-8">
        {t(locale, 'team.ctaText')}
      </p>
      <CTAButton
        href={getLocalePath(locale, 'contact')}
        text={t(locale, 'contact.schedule')}
        variant="primary"
        arrow={true}
      />
    </div>
  </section>
</PageLayout>
