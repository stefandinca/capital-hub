---
import { t, getLocalePath } from '../../i18n/index';
import PageLayout from '../../layouts/PageLayout.astro';
import SectionBadge from '../../components/shared/SectionBadge.astro';
import CTAButton from '../../components/shared/CTAButton.astro';

const locale = 'ro';

const stats = [
  { value: '600+', label: 'Companii' },
  { value: '250M+', label: 'Finantare' },
  { value: '98%', label: 'Rata succes' },
  { value: '15+', label: 'Ani experienta' },
];
---

<PageLayout locale={locale} pageKey="about">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-royal-blue via-royal-blue-2 to-royal-blue pt-32 pb-20 px-6">
    <div class="absolute top-20 right-20 w-72 h-72 bg-warm-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-96 h-96 bg-cta-teal/8 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-warm-gold/5 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-5xl mx-auto text-center">
      <SectionBadge text={t(locale, 'about.badge')} variant="dark" />

      <h1 class="text-3xl lg:text-5xl text-white font-bold leading-tight mt-4">
        {t(locale, 'about.title')}
      </h1>
      <p class="text-2xl lg:text-4xl text-warm-gold font-bold mt-4">
        {t(locale, 'about.titleHighlight')}
      </p>
    </div>
  </section>

  <!-- About Text Section -->
  <section class="py-16 lg:py-24 px-6 bg-white relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-warm-gold/5 rounded-full blur-3xl"></div>

    <div class="max-w-4xl mx-auto relative z-10">
      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        {t(locale, 'about.p1')}
      </p>
      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        {t(locale, 'about.p2')}
      </p>
      <p class="text-lg text-royal-blue font-semibold leading-relaxed border-l-4 border-cta-teal pl-6">
        {t(locale, 'about.p3')}
      </p>
    </div>
  </section>

  <!-- Image + Text Layout -->
  <section class="py-16 lg:py-24 px-6 bg-gray-50 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-80 h-80 bg-royal-blue/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-cta-teal/5 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Image -->
        <div class="relative">
          <img
            class="rounded-3xl w-full shadow-2xl object-cover aspect-[4/3]"
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&q=80"
            alt="Team collaboration"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-warm-gold/20 rounded-full blur-2xl"></div>
          <div class="absolute -top-4 -right-4 w-32 h-32 bg-cta-teal/15 rounded-full blur-2xl"></div>
        </div>

        <!-- Text Card -->
        <div class="bg-gradient-to-br from-royal-blue via-royal-blue-2 to-royal-blue rounded-3xl p-10 shadow-2xl relative overflow-hidden">
          <div class="absolute top-0 right-0 w-40 h-40 bg-warm-gold/10 rounded-full blur-3xl"></div>
          <div class="absolute bottom-0 left-0 w-48 h-48 bg-cta-teal/10 rounded-full blur-3xl"></div>

          <div class="relative z-10">
            <h3 class="text-2xl lg:text-3xl text-white font-bold mb-6">
              {t(locale, 'about.title')} <span class="text-warm-gold">{t(locale, 'about.titleHighlight')}</span>
            </h3>

            <p class="text-white/80 leading-relaxed mb-4">
              {t(locale, 'about.p1')}
            </p>

            <p class="text-white/70 leading-relaxed mb-8">
              {t(locale, 'about.p3')}
            </p>

            <CTAButton
              href={getLocalePath(locale, 'contact')}
              text={t(locale, 'about.teamCta')}
              variant="primary"
              arrow={true}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-16 lg:py-24 px-6 bg-gradient-to-br from-royal-blue via-royal-blue-2 to-royal-blue relative overflow-hidden">
    <div class="absolute top-10 left-10 w-72 h-72 bg-warm-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-80 h-80 bg-cta-teal/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-warm-gold/5 rounded-full blur-3xl"></div>

    <div class="max-w-6xl mx-auto relative z-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {stats.map((stat) => (
          <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-3xl p-8 text-center shadow-xl hover:bg-white/15 transition duration-500">
            <p class="text-4xl lg:text-5xl font-bold text-warm-gold mb-2">{stat.value}</p>
            <p class="text-white/80 text-sm font-semibold uppercase tracking-wider">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team CTA Section -->
  <section class="py-16 lg:py-24 px-6 bg-white relative overflow-hidden">
    <div class="absolute top-10 right-10 w-64 h-64 bg-cta-teal/5 rounded-full blur-3xl"></div>

    <div class="max-w-3xl mx-auto text-center relative z-10">
      <CTAButton
        href={getLocalePath(locale, 'contact')}
        text={t(locale, 'about.teamCta')}
        variant="primary"
        arrow={true}
      />
    </div>
  </section>
</PageLayout>
