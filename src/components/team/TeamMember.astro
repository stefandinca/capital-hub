---
interface Props {
  photo: string;
  alt: string;
  name: string;
  role: string;
  bio: string;
  strengthsLabel: string;
  strengths: string[];
}

const { photo, alt, name, role, bio, strengthsLabel, strengths } = Astro.props;
---

<article class="group bg-white rounded-3xl shadow-xl p-8 lg:p-10 flex flex-col relative overflow-hidden transition duration-500 hover:shadow-2xl">
  <div class="absolute -top-16 -right-16 w-48 h-48 bg-warm-gold/10 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-16 -left-16 w-48 h-48 bg-cta-teal/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 flex flex-col items-center text-center mb-6">
    <div class="relative mb-5">
      <div class="absolute inset-0 bg-warm-gold/20 rounded-full blur-2xl"></div>
      <img
        src={photo}
        alt={alt}
        width="160"
        height="160"
        loading="lazy"
        decoding="async"
        class="relative w-36 h-36 lg:w-40 lg:h-40 rounded-full object-cover ring-4 ring-warm-gold/30 shadow-lg"
      />
    </div>
    <h3 class="text-2xl text-royal-blue font-bold">{name}</h3>
    <p class="mt-2 text-xs text-cta-teal font-bold uppercase tracking-wider">{role}</p>
  </div>

  <p class="relative z-10 text-gray-700 leading-relaxed mb-6">{bio}</p>

  <div class="relative z-10 bg-off-off-white rounded-2xl p-6 mt-auto border border-gray-100">
    <p class="text-xs font-bold text-royal-blue uppercase tracking-wider mb-4">{strengthsLabel}</p>
    <ul class="space-y-3">
      {strengths.map((item) => (
        <li class="flex items-start gap-3 text-sm text-gray-700 leading-relaxed">
          <svg class="w-4 h-4 text-cta-teal flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</article>
