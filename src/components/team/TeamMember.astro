---
type Variant = 'leadership' | 'expert';
type Banner = 'blue' | 'teal' | 'gold' | 'blue-2';

interface Props {
  photo?: string;
  alt: string;
  name: string;
  role: string;
  bio: string;
  strengthsLabel: string;
  strengths: string[];
  variant?: Variant;
  banner?: Banner;
}

const {
  photo,
  alt,
  name,
  role,
  bio,
  strengthsLabel,
  strengths,
  variant = 'leadership',
  banner = 'blue',
} = Astro.props;

const bannerGradients: Record<Banner, string> = {
  'blue':   'from-royal-blue to-royal-blue-2',
  'teal':   'from-cta-teal to-cta-teal/80',
  'gold':   'from-warm-gold to-warm-gold/80',
  'blue-2': 'from-royal-blue-2 to-royal-blue',
};

const isLeader = variant === 'leadership';
const shortRole = role.replace(/\s*-\s*Capital Hub\s*$/, '');
---

<article class="bg-white rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl transition duration-500 border border-gray-100 flex flex-col">
  <!-- Banner -->
  <div class:list={[
    'relative overflow-hidden bg-gradient-to-br',
    bannerGradients[banner],
    isLeader ? 'h-64' : 'h-48',
  ]}>
    <div class="absolute inset-0 flex items-center justify-center">
      {photo ? (
        <img
          src={photo}
          alt={alt}
          width={isLeader ? 128 : 96}
          height={isLeader ? 128 : 96}
          loading="lazy"
          decoding="async"
          class:list={[
            'rounded-full object-cover ring-4 ring-white/30 shadow-lg',
            isLeader ? 'w-32 h-32' : 'w-24 h-24',
          ]}
        />
      ) : (
        <div
          class:list={[
            'bg-white/10 rounded-full flex items-center justify-center',
            isLeader ? 'w-32 h-32' : 'w-24 h-24',
          ]}
          role="img"
          aria-label={alt}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width={isLeader ? 64 : 48}
            height={isLeader ? 64 : 48}
            fill="white"
            viewBox="0 0 16 16"
            aria-hidden="true"
          >
            <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0" />
            <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1" />
          </svg>
        </div>
      )}
    </div>

    {isLeader && (
      <div class="absolute top-4 right-4">
        <div class="px-4 py-2 bg-warm-gold rounded-full">
          <p class="text-xs font-bold text-white whitespace-nowrap">{shortRole}</p>
        </div>
      </div>
    )}
  </div>

  <!-- Body -->
  <div class:list={[isLeader ? 'p-8' : 'p-6', 'flex flex-col flex-1']}>
    <h3 class:list={[
      'font-bold text-royal-blue',
      isLeader ? 'text-2xl mb-2' : 'text-xl mb-1',
    ]}>{name}</h3>
    <p class="text-cta-teal font-semibold text-sm mb-4">{role}</p>
    <p class:list={[
      'text-gray-600 leading-relaxed',
      isLeader ? 'mb-6' : 'text-sm mb-4',
    ]}>{bio}</p>

    <div class:list={[
      'border-t border-gray-200 mt-auto',
      isLeader ? 'pt-6' : 'pt-4',
    ]}>
      <p class:list={[
        'font-bold text-royal-blue',
        isLeader ? 'text-sm mb-3' : 'text-xs mb-2',
      ]}>{strengthsLabel}</p>
      <ul class:list={[isLeader ? 'space-y-2' : 'space-y-1.5']}>
        {strengths.map((item) => (
          <li class:list={[
            'flex items-start text-gray-600',
            isLeader ? 'text-sm' : 'text-xs',
          ]}>
            {isLeader ? (
              <svg class="w-4 h-4 text-cta-teal mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            ) : (
              <span class="w-1 h-1 bg-cta-teal rounded-full mr-2 mt-1.5 flex-shrink-0" aria-hidden="true"></span>
            )}
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</article>
