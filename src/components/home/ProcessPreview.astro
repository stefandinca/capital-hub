---
import { t, getLocalePath } from '../../i18n/index';
import SectionBadge from '../shared/SectionBadge.astro';

interface Props {
  locale: string;
}

const { locale } = Astro.props;

const steps = [
  { num: '01', key: 'step1', color: 'from-cta-teal to-cta-teal/80', accent: 'bg-cta-teal' },
  { num: '02', key: 'step2', color: 'from-warm-gold to-warm-gold/80', accent: 'bg-warm-gold' },
  { num: '03', key: 'step3', color: 'from-royal-blue to-royal-blue-2', accent: 'bg-royal-blue' },
  { num: '04', key: 'step4', color: 'from-cta-teal to-cta-teal/80', accent: 'bg-cta-teal' },
];
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-royal-blue via-royal-blue-2 to-royal-blue"></div>
  <div class="absolute top-20 left-10 w-72 h-72 bg-warm-gold/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 right-10 w-96 h-96 bg-cta-teal/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 px-6 lg:px-12 py-16 lg:py-32">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <SectionBadge text={t(locale, 'process.badge')} variant="dark" />
        <h2 class="text-3xl lg:text-5xl text-white font-bold max-w-4xl mx-auto leading-tight">
          {t(locale, 'process.title')} <span class="text-warm-gold">{t(locale, 'process.titleHighlight')}</span>
        </h2>
        <p class="mt-6 text-lg text-white/70 max-w-2xl mx-auto">
          {t(locale, 'process.subtitle')}
        </p>
      </div>

      <!-- Process Steps Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        {steps.map((step) => (
          <a href={getLocalePath(locale, 'services')} class="group relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl p-8 hover:bg-white/10 transition duration-500 overflow-hidden block">
            <div class="absolute inset-0 bg-gradient-to-br from-cta-teal/10 to-transparent opacity-0 group-hover:opacity-100 transition duration-500"></div>
            <div class="relative z-10">
              <div class:list={['w-12 h-12 rounded-2xl flex items-center justify-center mb-6', `bg-gradient-to-br ${step.color}`]}>
                <span class="text-white font-bold text-sm">{step.num}</span>
              </div>
              <h3 class="text-xl font-bold text-white mb-3">{t(locale, `process.${step.key}.title`)}</h3>
              <p class="text-white/70 text-sm leading-relaxed">{t(locale, `process.${step.key}.description`)}</p>
              <div class="mt-4 flex items-center text-cta-teal text-sm font-semibold group-hover:gap-2 gap-1 transition-all duration-300">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Special intervention card -->
      <div class="bg-warm-gold/10 border border-warm-gold/20 rounded-3xl p-8 text-center">
        <h3 class="text-xl font-bold text-white mb-2">{t(locale, 'process.special.title')}</h3>
        <p class="text-white/70 text-sm mb-4">{t(locale, 'process.special.description')}</p>
        <a href={getLocalePath(locale, 'services')} class="inline-flex items-center gap-2 text-warm-gold text-sm font-semibold hover:gap-3 transition-all duration-300">
          {t(locale, 'process.special.cta')}
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
        </a>
      </div>
    </div>
  </div>
</section>
