---
interface Props {
  href: string;
  text: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
  arrow?: boolean;
}

const { href, text, variant = 'primary', class: className = '', arrow = false } = Astro.props;

const classes = {
  primary: 'bg-cta-teal hover:bg-warm-gold text-white shadow-xl hover:scale-105',
  secondary: 'bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white border border-white/20 shadow-xl',
  outline: 'bg-white hover:bg-royal-blue text-royal-blue hover:text-white border border-royal-blue/20 shadow-lg',
};
---

<a href={href} class:list={['inline-flex items-center gap-2 py-4 px-8 rounded-full text-sm font-semibold transition ease-in-out duration-300', classes[variant], className]}>
  {text}
  {arrow && (
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  )}
</a>
